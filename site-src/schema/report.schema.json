{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiragram.github.io/daily-news/schema/report.schema.json",
  "title": "DailyNewsReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "date",
    "windowLabel",
    "archiveTitle",
    "archiveSummary",
    "latestSummary",
    "summaryBullets",
    "officialNews",
    "officialZeroStates",
    "signals",
    "releasePanels",
    "exclusions",
    "sources"
  ],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "windowLabel": {
      "type": "string",
      "minLength": 1
    },
    "archiveTitle": {
      "type": "string",
      "minLength": 1
    },
    "archiveSummary": {
      "type": "string",
      "minLength": 1
    },
    "latestSummary": {
      "type": "string",
      "minLength": 1
    },
    "summaryBullets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "officialNews": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/story"
      }
    },
    "officialZeroStates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/zeroState"
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/story"
      }
    },
    "releasePanels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/releasePanel"
      }
    },
    "exclusions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceLink"
      }
    }
  },
  "$defs": {
    "story": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "datetime",
        "displayTime",
        "title",
        "summary",
        "url",
        "urlLabel"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "datetime": {
          "type": "string",
          "format": "date-time"
        },
        "displayTime": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "urlLabel": {
          "type": "string",
          "minLength": 1
        },
        "primary": {
          "type": "boolean"
        }
      }
    },
    "zeroState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "body"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "releasePanel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "headline",
        "body"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "urlLabel": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "url"
            ]
          },
          "then": {
            "required": [
              "urlLabel"
            ]
          }
        }
      ]
    },
    "sourceLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "url"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
