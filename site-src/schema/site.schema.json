{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiragram.github.io/daily-news/schema/site.schema.json",
  "title": "DailyNewsSiteMeta",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "siteTitle",
    "siteHeadline",
    "siteDescription",
    "latestIssueDate"
  ],
  "properties": {
    "siteTitle": {
      "type": "string",
      "minLength": 1
    },
    "siteHeadline": {
      "type": "string",
      "minLength": 1
    },
    "siteDescription": {
      "type": "string",
      "minLength": 1
    },
    "latestIssueDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
